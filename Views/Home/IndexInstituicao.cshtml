@model List<MCMV.Models.CampanhaModel>

@{
    ViewData["Title"] = "Página Inicial - Minha Cidade, Minha Vida";

    // ✅ Não use Peek aqui (senão “vaza” pra outras páginas)
    var verifMensagem = TempData["VerifMensagem"] as string;
    var verifTipo = TempData["VerifTipo"] as string;
}


<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="shortcut icon" href="style/assets/favicon.ico" type="image/x-icon">
  <title>Painel da Instituição</title>
    <link rel="stylesheet" href="~/style/indexInstituicao.css">
</head>
<body>

<!-- Topo da Página -->

  <header class="topbar">
    <div class="logo">
            <img src="~/style/assets/logo.png" alt="Logo" style="height: 35px;" />
      <span>MINHA CIDADE<br>MINHA VIDA</span>
    </div>

    <!-- Botão Logout-->
        
        <form asp-controller="Home" asp-action="Logout" method="post" class="logout-form" aria-label="Sair">
            <button class= "btn-logout">
            ➜</button>
        </form>


    
  </header>

  <section class="top-section">
    <div class="top-section-titulo">
      <h1>Painel da instituição</h1>
      <a href="#modal-verificacao" class="btn-Modal">Verificação</a>
      <p>Gerencie suas atividades</p>
    </div>
    <div class="section-decoracao">
      <div class="figura semi-circulo"></div>
      <div class="figura circulo-listrado"></div>
      <div class="figura circulo"></div>
      <div class="figura gradiente-pontos"></div>
    </div>
  </section>

<!-- Conteúdo -->

  <main class="container">

    <div class="grid">

            <!-- Seleção de Campanha -->
            <div class="card selecao-campanha">
                <p>Selecione a campanha:</p>

                <!-- Seleção de Campanha Dinâmica -->
                <select id="selectCampanha" class="form-control">
                    <option value="">-- Selecione uma campanha --</option>
        
                    @if (Model != null && Model.Any())
                    {
                        foreach (var campanha in Model)
                        {
                            <option value="@campanha.Id">@campanha.Nome</option>
                        }
                    }
                </select>
    
                <p class="ou">Ou</p>
                <p>Registre uma nova campanha:</p>
                <a href="#modal-campanha" class="btn-Modal">Registrar</a>
            </div>

      <!-- Progresso de Campanha -->
            <div class="card progresso-campanha">
                <h2>Progresso da Campanha</h2>
                <p class="subtitulo">Acompanhe o progresso da campanha</p>
    
                <div class="progresso-linha">
                    <div class="coluna-total">
                        <p><strong>Total Geral</strong></p>
                        <div class="graficoTotal-container">
                            <canvas id="graficoCampanha"></canvas>
                            <span class="porcentagemTotal-numero" id="total-porcentagem">0%</span>
                        </div>
            
                        <div class="Legenda">
                            <span><span class="LegendaProgresso Concluido"></span> Concluído</span>
                            <span><span class="LegendaProgresso Pendente"></span> Pendente</span>
                        </div>

                        <div style="margin-top: 15px;">
                            <button type="button" id="btnTestarGrafico" class="btn-Modal" style="background: #333; font-size: 11px; padding: 5px 10px; width: 100%;">
                                Simular 100% (Teste)
                            </button>
                        </div>
                    </div>

                    <div class="coluna-categorias" id="listaCategoriasContainer">
                        <p><strong>Por categoria</strong></p>
                        <div id="listaCategorias">
                        </div>
                    </div>
                </div>
            </div>

            <div style="margin-top: 15px;">
                <button type="button" id="btnTestarGrafico" class="btn-Modal" style="background: #333; font-size: 12px; padding: 8px;">
                    Simular 100% (Teste)
                </button>
            </div>

          <div class="coluna-categorias">
           <p><strong>Por categoria</strong></p>

            <!-- Lista de Categorias -->

            <div id="listaCategorias">
           
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="grid baixo">

      <!-- Historico de Campanhas -->
       
      <div class="card historico-campanhas">
        <h2>Histórico de campanhas</h2>
        <p class="subtitulo">Registro de campanhas cadastradas</p>
        <div class="scroll-tabela">
          <table>
            <thead>
              <tr><th>Campanhas</th><th>Início</th><th>Fim</th><th>Status</th></tr>
            </thead>

            <!-- Tabela das campanhas registradas -->
            <tbody id="tabelaCampanhas">
                @if (Model != null && Model.Any())
                {
                    foreach (var campanha in Model)
                    {
                        <tr>
                            <td>@campanha.Nome</td>
                            <td>@campanha.DataInicio.ToString("dd/MM/yyyy")</td>
                            <td>@campanha.DataFim.ToString("dd/MM/yyyy")</td>
                            <td>
                                @{
                                    var status = campanha.DataFim < DateTime.Now ? "CONCLUÍDO" : "NÃO CONCLUÍDO";
                                    var classeStatus = campanha.DataFim < DateTime.Now ? "status-concluido" : "status-pendente";
                                }
                                <span class="@classeStatus">@status</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" style="text-align:center">Nenhuma campanha registrada.</td>
                    </tr>
                }
            </tbody>

          </table>
        </div>
      </div>

      <!-- Historico de Doações -->

      <div class="card historico-doacoes">
       <h2>Histórico de doações</h2>
       <p class="subtitulo">Registro de doações realizadas</p>


        <!-- Lista de Doações -->
        <div class="scroll-doacoes" id="listaDoacoes"></div>

      </div>

    </div>

  </main>
 
  <div id="modal-verificacao" class="modal-overlay">
        <div class="modal">

            <div class="modal-header">
                <div>
                    <h2>Valide sua Instituição</h2>
                    <p class="modal-subtitulo">
                        Faça a sua verificação para gerar mais confiança
                    </p>
                </div>
                <a href="#" class="modal-fechar">✕</a>
            </div>

            <!-- ✅ CORPO PADRÃO -->
            <!-- ✅ A CAIXA FLUTUANTE DENTRO DO MODAL -->
            @if (!string.IsNullOrEmpty(verifMensagem))
            {
                <div id="verifToast" class="verif-toast @(verifTipo ?? "aviso")">
                    <strong class="verif-title">
                        
                    @(verifTipo == "sucesso" ? "✅ Verificação concluída"
                        : verifTipo == "erro" ? "Ops!"
                        : "⚠️ Aviso")

                    </strong>
                    <div class="verif-msg">@verifMensagem</div>
                </div>
            }

            <form class="modal-corpo"
                  method="post"
                  enctype="multipart/form-data"
                  asp-controller="Home"
                  asp-action="FazerVerificacao">
               <div class="campo">
                    <label>
                        Comprovante da instituição
                        <span class="obrigatorio">*</span>
                    </label>

                    <label for="documentoInstituicao" class="file-input-fake">
                        <span id="fileText">Selecionar arquivo</span>
                    </label>

                    <input type="file"
                           id="documentoInstituicao"
                           name="imagem"
                           accept=".pdf,.png,.jpg,.jpeg"
                           hidden required>
                </div>
                <p>Se você não tem um documento oficial de sua intituição, acesse os links abaixo e solicite seu comprovante:</p>
                <a href="https://www.gov.br/pt-br/servicos/qualificar-entidade-como-organizacao-da-sociedade-civil-de-interesse-publico" target="_blank">Ir para o Site da OSCIP <img src="~/style/assets/brasil.png" alt="Bandeira do Brasil" style="width: 20px; vertical-align: middle;" /></a>
                <a href="https://www.gov.br/mds/pt-br/acoes-e-programas/suas/entidades-de-assistencia-social/certificacao-de-entidades-de-assistencia-social" target="_blank">
                    Ir para o Site da CEBAS
                    <img src="~/style/assets/brasil.png" alt="Bandeira do Brasil" style="width: 20px; vertical-align: middle;" />
                    </a>
            

            <!-- ✅ RODAPÉ PADRÃO -->
                <div class="modal-rodape">
                    <a href="#" class="btn-cancelar">Cancelar</a>
                    <button type="submit" class="btn-verde btn-registrar">
                        Fazer a Verificação
                    </button>
                </div>

            </form>

        </div>
    </div>

  <!-- Modal (Registrar Campanha) — 
   abre:target (href="#modal-campanha") 
   fecha href="#" -->
   
  <div id="modal-campanha" class="modal-overlay">
    <div class="modal">

      <div class="modal-header">
        <div>
          <h2>Registrar nova campanha</h2>
          <p class="modal-subtitulo">Preencha os dados da campanha</p>
        </div>

        <!-- Fechar o Modal removendo da URL -->
        <a href="#" class="modal-fechar" aria-label="Fechar">✕</a>
      </div>

      <!-- action e method -->
           <form class="modal-corpo" method="post" asp-controller="Home" asp-action="RegistrarCampanha">

        <!-- Identificação da campanha -->

        <div class="modal-secao">
          <span class="modal-secao-label">Identificação</span>
          <div class="campo">

            <label for="campNome"> Nome da Campanha <span class="obrigatorio">*</span></label>

            <!-- Nome da campanha -->
            <input type="text" id="campNome" name="nomeDaCampanha" placeholder="Ex: Campanha do Agasalho 2026" required maxlength="30">


          </div>
        </div>

        <!-- Endereço da Campanha -->
        <div class="modal-secao">
          <span class="modal-secao-label">Endereço</span>
          <div class="modal-grid">
            <div class="campo largo">
              <label for="campRua">Rua <span class="obrigatorio">*</span></label>

              <!-- Rua -->
              <input type="text" id="campRua" name="rua" placeholder="Ex: Rua das Flores" required>

            </div>
            <div class="campo pequeno">
              <label for="campCep">CEP <span class="obrigatorio">*</span></label>

              <!-- CEP -->
              <input type="text" id="campCep" name="cep" placeholder="00000-000" required pattern="\d{5}-?\d{3}" maxlength="9">


            </div>
            <div class="campo pequeno">
              <label for="NumeroEnderec">Número <span class="obrigatorio">*</span></label>

              <!-- Número do Endereço -->
              <input type="text" id="NumeroEnderec" name="numeroEnderec" placeholder="Ex: 123" required>


            </div>
            <div class="campo">
              <label for="Bairro">Bairro <span class="obrigatorio">*</span></label>

              <!-- Bairro -->
              <input type="text" id="Bairro" name="bairro" placeholder="Ex: Centro" required>
            </div>
          </div>
        </div>

        <!-- Categoria de itens (doação) -->

        <div class="modal-secao">
          <span class="modal-secao-label">Categorias de itens <span class="modal-hint">(até 3)</span></span>
          <div class="categoria-linha">
            <div class="campo medio">
              <label>Categoria 1 <span class="obrigatorio">*</span></label>

              <!-- Nome Categoria 1 -->
              <input type="text" name="cat1_nome" placeholder="Ex: Alimentos" required></div>

            <div class="campo pequeno"><label>Meta</label>
              
              <!-- Meta Categoria 1 -->
              <input type="number" name="cat1_meta" placeholder="100" min="1"></div>

            <div class="campo pequeno"><label>Unidade</label>
              
              <!-- Unidade Categoria 1 -->
              <select name="cat1_unidade"><option>UNI</option><option>KG</option><option>L</option><option>CX</option></select></div>
          </div>

          <div class="categoria-linha">
            <div class="campo medio"><label>Categoria 2</label>
              
              <!-- Nome Categoria 2 -->
              <input type="text" name="cat2_nome" placeholder="Ex: Roupas"></div>

            <div class="campo pequeno"><label>Meta</label>
              
              <!-- Meta Categoria 2 -->
              <input type="number" name="cat2_meta" placeholder="100" min="1"></div>

            <div class="campo pequeno"><label>Unidade</label>
              
              <!-- Unidade Categoria 2 -->
              <select name="cat2_unidade"><option>UNI</option><option>KG</option><option>L</option><option>CX</option></select></div>
          </div>

          <div class="categoria-linha">

            <div class="campo medio"><label>Categoria 3</label>
              
              <!-- Nome Categoria 3 -->
              <input type="text" name="cat3_nome" placeholder="Ex: Limpeza"></div>

            <div class="campo pequeno"><label>Meta</label>
              
              <!-- Meta Categoria 3 -->
              <input type="number" name="cat3_meta" placeholder="100" min="1"></div>

            <div class="campo pequeno"><label>Unidade</label>
              
              <!-- Unidade Categoria 3 -->
              <select name="cat3_unidade"><option>UNI</option><option>KG</option><option>L</option><option>CX</option></select></div>

          </div>
        </div>

        <div class="modal-secao">
          <span class="modal-secao-label">Período</span>
          <div class="modal-grid">
            <div class="campo">
              <label for="campInicio">Data de início <span class="obrigatorio">*</span></label>

              <!-- Data de Início-->
              <input type="date" id="campInicio" name="data_inicio" required>

            </div>
            <div class="campo">
              <label for="campFim">Data de finalização <span class="obrigatorio">*</span></label>

              <!-- Data de Fim -->
              <input type="date" id="campFim" name="data_fim" required>

            </div>
          </div>
        </div>

        <div class="modal-secao">
          <span class="modal-secao-label">Descrição <span class="modal-hint">(opcional)</span></span>
          <div class="campo">

            <!-- Descrição (opcional)-->
            <textarea name="descricao" rows="3" placeholder="Descreva o objetivo ou contexto da campanha..."></textarea>

          </div>
        </div>

        <div class="modal-rodape">

          <!-- Fecha o Modal -->
          <a href="#" class="btn-cancelar">Cancelar</a>

          <!-- Botão de Registro da Campanha -->
          <button type="submit" class="btn-verde btn-registrar">Registrar campanha</button>

        </div>

      </form>
    </div>
  </div>

<script>
       
   document.addEventListener('DOMContentLoaded', function () {

  /* Barras de progresso */

  document.querySelectorAll('.barra-preenchimento').forEach(function (b) {
    b.style.width = b.getAttribute('data-porcentagem') + '%';
  });

  /* Redirecionamento do logout */
  window.redLogin = function () 
  {
        window.location.href = '@Url.Action("Login", "Home")';              
  };


});

const uploadArea = document.getElementById("uploadArea");
const fileText = document.getElementById("fileText");

document.getElementById("documentoInstituicao")
    ?.addEventListener("change", function() {
        const fileText = document.getElementById("fileText");
        if (this.files.length > 0) {
            fileText.textContent = this.files[0].name;
            fileText.style.color = "#000";
        }

});

(function () {
    const toast = document.getElementById("verifToast");
    if (toast) {
    setTimeout(() => {
        toast.classList.add("hide");
        setTimeout(() => toast.remove(), 450);
    }, 5000); // tempo visível (ms)
    }
})();

</script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="~/js/ProgressoCampanha.js"></script>

</body>
</html>

