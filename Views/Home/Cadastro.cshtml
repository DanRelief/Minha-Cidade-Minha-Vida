@{
    // Define que esta página não usará o _Layout.cshtml global.
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro - Minha Cidade, Minha Vida</title>
    <link rel="stylesheet" href="~/style/cadastro.css">
    </head>
    <body>
        <div class="panel">
            <div class="left">
                <h1>Já possui conta?</h1>
                <p>Acesse agora clicando em Login!</p>
                <button id="btnLogin" type="button" onclick="location.href='@Url.Action("Login", "Home")'">
                    Login
                </button>
                <img src="~/style/assets/doacao_ilust.png" class="doacao-ilust" alt="Ilustração de doação">
                </div>

                <div class="right">
                    <h2>Cadastre-se</h2>

                    @* Bloco C#: Se houver alguma mensagem de erro vinda do Controller, ela será exibida aqui *@
                    @if (ViewBag.Erro != null)
                    {
                        <p style="color:red; font-size:12px;">@ViewBag.Erro</p>
                    }

                    @* asp-action="Cadastro" indica que, ao clicar no botão, os dados serão enviados para o método Cadastro no HomeController *@
                        <form asp-action="Cadastro" method="post" enctype="multipart/form-data">
                        <label for="user">Nome:</label>
                        <input type="text" id="user" name="user" maxlength="50" required>

                        @* Este label e input mudam dinamicamente entre CPF e CNPJ via JavaScript abaixo *@
                        <label id="labelIdentific" for="identific">CPF:</label>
                        <input type="text" id="identific" name="identific" maxlength="14" required>

                        <div class="checkbox-area">
                            @* Checkbox para indicar se o usuário é pessoa física ou uma Instituição *@
                            <input type="checkbox" id="isInstit" name="isInstit" value="true">
                            <label for="isInstit">Sou uma instituição</label>
                        </div>
                        

                        <div class="file-upload" id="uploadArea" style="display:none;">
                        <label>Comprovante da instituição (PDF, PNG ou JPEG):</label>
                            <label for="documentoInstituicao" class="file-label">
                                <span id="fileText">Selecionar arquivo</span>
                            </label>

                            <input type="file"
                                   id="documentoInstituicao"
                                   name="documentoInstituicao"
                                   accept=".pdf,.png,.jpg,.jpeg"
                                   hidden />
                        </div>



                        <label for="email">E-mail:</label>
                        <input type="email" id="email" name="email" required>

                        <label for="senha">Senha:</label>
                        <input type="password" id="senha" name="senha" required>

                        <label for="confirmarSenha">Confirme a senha:</label>
                        <input type="password" id="confirmarSenha" name="confirmarSenha" required>

                        <button id="btnRegistrar" type="submit">Registrar</button>
                    </form>
                </div>
            </div>

        <script>
                const checkbox = document.getElementById("isInstit");
                const label = document.getElementById("labelIdentific");
                const inputIdentific = document.getElementById("identific");
                const uploadArea = document.getElementById("uploadArea");

                const fileInput = document.getElementById("documentoInstituicao");
                const fileText = document.getElementById("fileText");

                if (fileInput && fileText) {
                    fileInput.addEventListener("change", () => {
                        fileText.textContent =
                            fileInput.files.length > 0
                                ? fileInput.files[0].name
                                : "Selecionar arquivo";
                    });
                }

                checkbox.addEventListener("change", () => {
                    if (checkbox.checked) {
                        label.innerText = "CNPJ:";
                        inputIdentific.maxLength = 14;
                        uploadArea.style.display = "block";
                    } else {
                        label.innerText = "CPF:";
                        inputIdentific.maxLength = 11;
                        uploadArea.style.display = "none";
                        if (fileText) fileText.textContent = "Selecionar arquivo";
                    }

                    inputIdentific.value = "";
                });
        </script>
        </body>
    </html>